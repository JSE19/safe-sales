// SafeSale Prisma schema
// Generated client lives in node_modules/.prisma/client (default).
// Mirrors the domain types in the frontend at src/lib/types.ts so the
// API contracts and DB stay aligned.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// EscrowStatus — the state machine an Order moves through
// --------------------------------------------------------------------------
enum EscrowStatus {
  pending_payment // Order created, awaiting buyer bank transfer
  payment_locked // Bitnob confirmed; Cashu token minted & P2PK-locked to buyer
  shipped // Seller marked shipped; 7-day auto-release countdown begins
  delivered // Buyer marked received (optional intermediate step)
  completed // Token released, fee taken, seller paid
  disputed // Buyer opened dispute; token frozen
  refunded // Token returned to buyer via Bitnob NGN payout
}

// --------------------------------------------------------------------------
// DisputeStatus — mediation lifecycle
// --------------------------------------------------------------------------
enum DisputeStatus {
  direct_resolution // 72h peer window
  escalated // Auto-escalated to admin after 72h
  evidence_requested // Admin asked for more evidence (24h sub-window)
  mediating // Admin actively reviewing
  resolved // Closed; see `resolution` JSON
}

// --------------------------------------------------------------------------
// Seller — the merchant. Identified by npub (their Nostr public key).
// --------------------------------------------------------------------------
model Seller {
  id       String  @id @default(cuid())
  npub     String  @unique // Bech32 Nostr public key
  pubkey   String  @unique // Hex form (for relay filter convenience)
  handle   String  @unique // URL-safe slug for /:handle storefront
  name     String
  location String
  phone    String
  category String
  bio      String?

  // Payout details — NGN bank transfer (off-ramp via Bitnob, mocked for MVP)
  bankName    String?
  bankAccount String?
  bankHolder  String?

  // OR direct Lightning payout (preferred for MVP since Bitnob is mocked)
  lnAddress String?

  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  orders   Order[]

  @@index([handle])
}

// --------------------------------------------------------------------------
// Listing — a product the seller is selling. Published as NIP-15 kind 30018.
// --------------------------------------------------------------------------
model Listing {
  id       String @id @default(cuid())
  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  title       String
  description String
  priceNGN    Int // Stored in whole naira (kobo precision unnecessary at this scale)
  images      Json // Array of { url, alt } objects
  category    String
  variants    Json? // Optional array of variant strings
  inStock     Int     @default(1)
  delivery    String?
  active      Boolean @default(true)

  // Cross-reference to the published Nostr event so clients can verify
  nostrEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([sellerId])
  @@index([active])
}

// --------------------------------------------------------------------------
// Order — a buyer-seller transaction. The orderToken is the buyer's only
// credential (no buyer account exists). See PRD: "Buyer never needs an account."
// --------------------------------------------------------------------------
model Order {
  id         String @id @default(cuid())
  shortId    String @unique // Human-friendly "SS-7421" for support
  orderToken String @unique // 22-char base32 secret in /order/:token URL

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  sellerId  String
  seller    Seller  @relation(fields: [sellerId], references: [id])

  // Buyer's one-time Nostr pubkey (hex). The Cashu token is P2PK-locked to
  // this key — only the holder of the matching secret can release the funds.
  buyerNpub   String
  buyerPubkey String

  buyerName     String
  buyerPhone    String
  buyerEmail    String?
  buyerCity     String
  buyerAddress  String?
  contactMethod String? // "phone" | "email"

  variant String?

  amountNGN  Int
  amountSats Int

  status EscrowStatus @default(pending_payment)

  // The locked Cashu token (serialized cashuA... blob). Stored encrypted
  // post-MVP; for hackathon stored as-is since the testnet mint has no
  // real funds at stake.
  cashuToken String?

  // Bitnob virtual account assigned at order creation (24h expiry)
  bitnobAccount String?
  bitnobBank    String?

  trackingNumber String?
  carrier        String?

  shippedAt  DateTime?
  releasedAt DateTime?
  refundedAt DateTime?

  // 7 days after shipped — silent-buyer protection
  autoReleaseAt DateTime?
  // Virtual account expiry
  expiresAt     DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispute Dispute?

  @@index([sellerId])
  @@index([buyerPubkey])
  @@index([status])
  @@index([autoReleaseAt]) // background job scans here
}

// --------------------------------------------------------------------------
// Dispute — opened against an Order. One per order max (1:1).
// --------------------------------------------------------------------------
model Dispute {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  reason   String
  summary  String?
  openedBy String // "buyer" | "seller"
  priority String  @default("medium") // "low" | "medium" | "high"

  status DisputeStatus @default(direct_resolution)

  // 72h after open — auto-escalation deadline
  directResolutionUntil DateTime?
  // 24h after evidence-request deadline
  evidenceDueAt         DateTime?

  isReturn       Boolean @default(false)
  // Three-checkpoint photo flow if a physical return is involved
  returnEvidence Json?

  // Final outcome — set when status flips to resolved
  resolution Json?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status])
}
