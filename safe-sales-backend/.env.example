# ============================================================================
# SafeSale Backend — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production (Railway), set these via the Railway dashboard.
# NEVER commit a populated .env file.
# ============================================================================

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Comma-separated list of allowed frontend origins (CORS)
# Exact match only. For wildcard-style patterns use FRONTEND_ORIGIN_REGEXES.
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:5173

# Comma-separated regex patterns matched against the request Origin.
# Defaults to allowing every *.vercel.app subdomain (covers production AND
# preview deploys). Escape backslashes since this is a string.
# Examples:
#   ^https://([a-z0-9-]+\.)*vercel\.app$        (any vercel.app subdomain)
#   ^https://([a-z0-9-]+\.)*netlify\.app$       (any netlify.app subdomain)
#   ^https://([a-z0-9-]+\.)*shopke\.org$        (any shopke.org subdomain)
FRONTEND_ORIGIN_REGEXES=^https://([a-z0-9-]+\.)*vercel\.app$

# Public frontend URL used in buyer emails, no trailing slash
FRONTEND_APP_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Database (Railway provides this automatically in prod)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/safesale

# ----------------------------------------------------------------------------
# SafeSale brand Nostr identity
# Generated once via `npm run keys:generate`. KEEP THE NSEC SECRET.
# Used to publish system DMs to sellers and sign mediator decisions.
# ----------------------------------------------------------------------------
SAFESALE_NSEC=
SAFESALE_NPUB=

# ----------------------------------------------------------------------------
# Mediator Nostr identity (MVP: same as SAFESALE_NSEC, can split later)
# ----------------------------------------------------------------------------
MEDIATOR_NSEC=
MEDIATOR_NPUB=

# ----------------------------------------------------------------------------
# Cashu mint
# Must support NUT-11 (P2PK locking). Verify before use.
# ----------------------------------------------------------------------------
CASHU_MINT_URL=https://testnut.cashu.space

# ----------------------------------------------------------------------------
# Lightning addresses
# SAFESALE_FEE_LN_ADDRESS receives the 1% take rate on successful trades.
# Each seller's payout LN address lives in the Seller table.
# ----------------------------------------------------------------------------
SAFESALE_FEE_LN_ADDRESS=

# ----------------------------------------------------------------------------
# Nostr relays (comma-separated)
# ----------------------------------------------------------------------------
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# ----------------------------------------------------------------------------
# Bitnob (sandbox — leave empty while mocked)
# ----------------------------------------------------------------------------
BITNOB_API_KEY=
BITNOB_WEBHOOK_SECRET=
BITNOB_BASE_URL=https://sandboxapi.bitnob.co

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
# RESEND_FROM_EMAIL can use Resend's test sender for local demos:
#   SafeSale <onboarding@resend.dev>     (only delivers to your Resend
#                                         account email; rate-limited)
#
# For production, use a verified sender on your own domain, e.g.:
#   SafeSale <orders@shopke.org>         (must be 'Verified' in the
#                                         Resend dashboard first)
RESEND_API_KEY=
RESEND_FROM_EMAIL=SafeSale <onboarding@resend.dev>
# Required in development/test when using onboarding@resend.dev.
# Set this to the verified email address on your Resend account.
# Unset this in production (the @resend.dev redirect only fires in dev).
RESEND_TEST_TO_EMAIL=
