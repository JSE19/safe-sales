# ============================================================================
# SafeSale Backend — Environment Variables
# ============================================================================

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

FRONTEND_ORIGINS=http://localhost:8080,http://localhost:5173
FRONTEND_ORIGIN_REGEXES=^https://([a-z0-9-]+\.)*vercel\.app$
FRONTEND_APP_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/safesale

# ----------------------------------------------------------------------------
# SafeSale brand Nostr identity
# ----------------------------------------------------------------------------
SAFESALE_NSEC=
SAFESALE_NPUB=

# ----------------------------------------------------------------------------
# Mediator Nostr identity
# ----------------------------------------------------------------------------
MEDIATOR_NSEC=
MEDIATOR_NPUB=

# ----------------------------------------------------------------------------
# Nostr relays
# ----------------------------------------------------------------------------
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# ----------------------------------------------------------------------------
# Mavapay
# Get these from your Mavapay dashboard under API settings.
# Use sandbox keys during development, live keys in production.
# ----------------------------------------------------------------------------
MAVAPAY_READ_KEY=
MAVAPAY_WRITE_KEY=

# The webhook signing secret. MavaPay provides this when you register
# a webhook URL in their dashboard (Settings → Webhooks → Add endpoint).
# Leave empty during local dev — the server skips signature verification
# when no secret is configured.
MAVAPAY_WEBHOOK_SECRET=

MAVAPAY_BASE_URL=https://sandbox.mavapay.co

# The Cloudflare tunnel URL that points to this backend on your machine.
# MavaPay uses this to deliver payment webhooks to your local dev server.
# Set up: cloudflared tunnel --url http://localhost:3000
# Copy the *.trycloudflare.com URL here. No trailing slash.
# In production (Railway), set this to your actual backend domain.
MAVAPAY_WEBHOOK_BASE_URL=https://your-tunnel.trycloudflare.com

# ----------------------------------------------------------------------------
# SafeSale fee collection
# ----------------------------------------------------------------------------
SAFESALE_FEE_LN_ADDRESS=

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=SafeSale <onboarding@resend.dev>
RESEND_TEST_TO_EMAIL=
