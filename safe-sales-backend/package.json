{
  "name": "safe-sale-backend",
  "version": "0.1.0",
  "description": "SafeSale backend API — trustless escrow for Instagram & WhatsApp commerce. Hack4Freedom submission.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bitcoin",
    "lightning",
    "nostr",
    "cashu",
    "escrow",
    "hack4freedom"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cashu/cashu-ts": "^2.5.2",
    "@fastify/cors": "^10.0.1",
    "@nostrify/nostrify": "^0.52.0",
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nostr-tools": "^2.10.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
